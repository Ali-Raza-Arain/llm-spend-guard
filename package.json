{
  "name": "llm-spend-guard",
  "version": "2.0.4",
  "description": "Enforce real-time token budgets and spending limits for OpenAI, Anthropic Claude, and Google Gemini API calls in Node.js",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "jest",
    "prepublishOnly": "npm run build",
    "lint": "tsc --noEmit",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "keywords": [
    "llm",
    "openai",
    "anthropic",
    "gemini",
    "token",
    "budget",
    "cost",
    "guard",
    "rate-limit",
    "claude",
    "ai",
    "gpt",
    "token-budget",
    "llm-cost",
    "api-cost-control",
    "spending-limit",
    "token-limit",
    "ai-cost-management",
    "gpt-4",
    "gpt-4o"
  ],
  "author": "Ali Raza Arain",
  "homepage": "https://ali-raza-arain.github.io/llm-spend-guard/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ali-Raza-Arain/llm-spend-guard.git"
  },
  "bugs": {
    "url": "https://github.com/Ali-Raza-Arain/llm-spend-guard/issues"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitepress": "^1.6.4"
  },
  "dependencies": {
    "tiktoken": "^1.0.15"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.20.0",
    "@google/generative-ai": ">=0.2.0",
    "ioredis": ">=5.0.0",
    "openai": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "openai": {
      "optional": true
    },
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "@google/generative-ai": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
